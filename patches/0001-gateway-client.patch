+        );
+
+        if (! $response instanceof ListNotificationsResponse) {
+            throw new GatewayRpcException($name, 2, 'Unexpected response type.');
+        }
+
+        $notifications = [];
+
+        foreach ($response->getNotifications() as $notification) {
+            if ($notification instanceof Notification) {
