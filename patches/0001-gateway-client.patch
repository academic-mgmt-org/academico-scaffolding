+            'id' => $notification->getId(),
+            'user_id' => $notification->getUsuarioId(),
+            'title' => $notification->getTitulo(),
+            'message' => $notification->getMensaje(),
+            'type' => $notification->getTipo(),
+            'channel' => $notification->getCanal(),
+            'priority' => $notification->getPrioridad(),
+            'state' => $notification->getEstado(),
