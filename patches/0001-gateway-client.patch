+            $accessToken,
+            $userId,
+            '',
+            $limit,
+            fn (ListNotificationsRequest $request, array $metadata, array $options) => $this->notifications
+                ->RecentNotifications($request, $metadata, $options),
+        );
+    }
+
+    /**
+     * @param  Closure(ListNotificationsRequest, array<string, list<string>>, array<string, int>): mixed  $rpc
+     * @return list<array<string, bool|string>>
+     */
+    private function listNotifications(
+        string $name,
+        string $accessToken,
+        string $userId,
+        string $state,
+        int $limit,
+        Closure $rpc,
+    ): array {
+        $request = (new ListNotificationsRequest)
+            ->setUsuarioId($userId)
+            ->setEstado($state)
+            ->setLimit($this->limit($limit));
+
+        $response = $this->call(
+            $name,
