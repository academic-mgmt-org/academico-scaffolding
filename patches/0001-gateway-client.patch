+        if ($statusCode !== 0) {
+            throw new GatewayRpcException($name, $statusCode, (string) ($status->details ?? 'Unknown error.'));
+        }
+
+        if (! is_object($response)) {
+            throw new GatewayRpcException($name, 2, 'The gateway returned an empty response.');
+        }
+
+        return $response;
+    }
+
+    /**
