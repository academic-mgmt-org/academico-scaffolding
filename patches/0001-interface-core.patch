 namespace App\Http\Controllers;
 
+use App\Contracts\AcademicGateway;
+use App\Exceptions\AcademicGatewayException;
+use Illuminate\Http\RedirectResponse;
 use Illuminate\Http\Request;
+use Illuminate\Support\Facades\Log;
+use Illuminate\Validation\Rules\Password;
+use Illuminate\View\View;
+use Throwable;
 
 class AcademicSessionController extends Controller
 {
-    //
+    public function __construct(private readonly AcademicGateway $gateway) {}
+
+    public function loginForm(Request $request): View|RedirectResponse
+    {
+        if ($this->accessToken($request) !== '') {
+            return redirect()->route('academic.interface');
+        }
+
+        return view('academic-interface::login');
+    }
+
+    public function login(Request $request): RedirectResponse
+    {
+        /** @var array{username: string, password: string} $validated */
+        $validated = $request->validate([
+            'username' => ['required', 'string', 'max:255'],
+            'password' => ['required', 'string', 'max:5000'],
+        ]);
+
+        try {
+            $session = $this->gateway->invoke('auth.v1.AuthService/Login', [
+                'username' => trim($validated['username']),
+                'password' => $validated['password'],
+                'appVersion' => (string) config('academic-interface.app_version'),
+                'passwordEncoding' => (string) config('academic-interface.password_encoding'),
+            ]);
+
+            $accessToken = (string) ($session['accessToken'] ?? '');
+            $refreshToken = (string) ($session['refreshToken'] ?? '');
+
+            if ($accessToken === '' || $refreshToken === '') {
+                throw new AcademicGatewayException('auth.v1.AuthService/Login', 2, 'The response omitted session tokens.');
+            }
+
+            $identity = $this->validateIdentity($accessToken);
+            $this->storeSession($request, $session, $identity);
+        } catch (AcademicGatewayException $exception) {
+            Log::notice('Academic interface login failed.', [
+                'rpc' => $exception->rpc,
+                'status_code' => $exception->statusCode,
+            ]);
+
+            return back()->withInput($request->except('password'))->withErrors([
+                'username' => $exception->isAuthenticationFailure()
+                    ? 'Las credenciales no son válidas.'
+                    : 'El servicio de autenticación no está disponible.',
+            ]);
+        }
+
+        return redirect()->route('academic.interface');
+    }
+
+    public function refresh(Request $request): RedirectResponse
+    {
+        $refreshToken = (string) $request->session()->get($this->sessionKey('refresh_token'), '');
+
+        if ($refreshToken === '') {
+            return $this->clearAndRedirect($request, 'La sesión no tiene refresh token.');
+        }
+
+        try {
+            $session = $this->gateway->invoke('auth.v1.AuthService/RefreshToken', [
+                'refreshToken' => $refreshToken,
+            ]);
+            $session['refreshToken'] = (string) ($session['refreshToken'] ?? $refreshToken);
+            $accessToken = (string) ($session['accessToken'] ?? '');
+
+            if ($accessToken === '') {
+                throw new AcademicGatewayException('auth.v1.AuthService/RefreshToken', 2, 'The response omitted the access token.');
+            }
+
+            $this->storeSession($request, $session, $this->validateIdentity($accessToken));
+        } catch (AcademicGatewayException) {
+            return $this->clearAndRedirect($request, 'La sesión no pudo renovarse. Inicia sesión nuevamente.');
+        }
+
+        return back()->with('academic_success', 'La sesión del gateway fue renovada.');
+    }
+
+    public function logout(Request $request): RedirectResponse
+    {
+        $accessToken = $this->accessToken($request);
+        $refreshToken = (string) $request->session()->get($this->sessionKey('refresh_token'), '');
+
+        try {
+            if ($accessToken !== '' || $refreshToken !== '') {
+                $this->gateway->invoke('auth.v1.AuthService/Logout', [
+                    'token' => $accessToken,
+                    'refreshToken' => $refreshToken,
+                ], $accessToken);
+            }
+        } catch (Throwable $exception) {
+            Log::warning('Remote academic logout failed; local session will still be invalidated.', [
+                'exception' => $exception::class,
+            ]);
+        }
+
+        $request->session()->invalidate();
+        $request->session()->regenerateToken();
+
+        return redirect()->route('academic.login')->with('status', 'Sesión cerrada.');
+    }
+
+    public function forgotForm(): View
+    {
+        return view('academic-interface::forgot-password');
+    }
+
+    public function sendResetLink(Request $request): RedirectResponse
+    {
+        /** @var array{email: string} $validated */
+        $validated = $request->validate([
+            'email' => ['required', 'email:rfc', 'max:255'],
+        ]);
+
+        try {
+            $this->gateway->invoke('auth.v1.AuthService/ForgotPassword', [
+                'email' => strtolower(trim($validated['email'])),
+            ]);
+        } catch (AcademicGatewayException $exception) {
+            Log::warning('Academic password reset request failed.', [
+                'rpc' => $exception->rpc,
+                'status_code' => $exception->statusCode,
+            ]);
+        }
+
+        return back()->with('status', 'Si la cuenta existe, recibirás las instrucciones de recuperación.');
+    }
+
+    public function resetForm(Request $request): View
+    {
+        return view('academic-interface::reset-password', [
+            'token' => (string) $request->query('token', ''),
+            'email' => (string) $request->query('email', ''),
+        ]);
+    }
+
+    public function resetPassword(Request $request): RedirectResponse
+    {
+        /** @var array{token: string, email: string, password: string} $validated */
+        $validated = $request->validate([
+            'token' => ['required', 'string', 'max:5000'],
+            'email' => ['required', 'email:rfc', 'max:255'],
+            'password' => ['required', 'confirmed', Password::defaults()],
+        ]);
+
+        try {
+            $this->gateway->invoke('auth.v1.AuthService/ResetPassword', [
+                'token' => $validated['token'],
+                'email' => strtolower(trim($validated['email'])),
+                'newPassword' => $validated['password'],
+                'passwordEncoding' => (string) config('academic-interface.password_encoding'),
+            ]);
+        } catch (AcademicGatewayException $exception) {
+            return back()->withInput($request->except('password', 'password_confirmation'))->withErrors([
+                'email' => 'No fue posible restablecer la contraseña: '.$this->friendlyStatus($exception),
+            ]);
+        }
+
+        return redirect()->route('academic.login')->with('status', 'Contraseña actualizada.');
+    }
+
+    /** @return array<string, mixed> */
+    private function validateIdentity(string $accessToken): array
+    {
+        $identity = $this->gateway->invoke('auth.v1.AuthService/ValidateToken', [
+            'token' => $accessToken,
+        ]);
+
+        if (! (bool) ($identity['isValid'] ?? false)) {
+            throw new AcademicGatewayException('auth.v1.AuthService/ValidateToken', 16, 'The issued token is not valid.');
+        }
+
+        return $identity;
+    }
+
+    /**
+     * @param  array<string, mixed>  $session
+     * @param  array<string, mixed>  $identity
+     */
+    private function storeSession(Request $request, array $session, array $identity): void
+    {
+        $request->session()->regenerate();
+        $request->session()->put([
+            $this->sessionKey('access_token') => (string) ($session['accessToken'] ?? ''),
+            $this->sessionKey('refresh_token') => (string) ($session['refreshToken'] ?? ''),
+            $this->sessionKey('session_id') => (string) ($session['sessionId'] ?? $identity['sessionId'] ?? ''),
+            $this->sessionKey('user_id') => (string) ($identity['userId'] ?? ''),
+            $this->sessionKey('identifier') => (string) ($identity['identifier'] ?? ''),
+            $this->sessionKey('email') => (string) ($identity['email'] ?? ''),
+            $this->sessionKey('role') => (string) ($identity['role'] ?? ''),
+        ]);
+    }
+
+    private function accessToken(Request $request): string
+    {
+        return (string) $request->session()->get($this->sessionKey('access_token'), '');
+    }
+
+    private function sessionKey(string $key): string
+    {
+        return (string) config("academic-interface.session.{$key}");
+    }
+
+    private function clearAndRedirect(Request $request, string $message): RedirectResponse
+    {
+        $request->session()->invalidate();
+        $request->session()->regenerateToken();
+
+        return redirect()->route('academic.login')->withErrors(['username' => $message]);
+    }
+
+    private function friendlyStatus(AcademicGatewayException $exception): string
+    {
+        return match ($exception->statusCode) {
+            3 => 'datos inválidos',
+            5 => 'token o cuenta no encontrados',
+            14 => 'servicio no disponible',
+            16 => 'token inválido o expirado',
+            default => 'respuesta gRPC '.$exception->statusCode,
+        };
+    }
 }
