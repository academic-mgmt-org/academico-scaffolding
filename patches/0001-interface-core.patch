diff --git a/app/Http/Controllers/AcademicInterfaceController.php b/app/Http/Controllers/AcademicInterfaceController.php
index 0badea4..10e5664 100644
--- a/app/Http/Controllers/AcademicInterfaceController.php
+++ b/app/Http/Controllers/AcademicInterfaceController.php
@@ -2,9 +2,276 @@
 
 namespace App\Http\Controllers;
 
+use App\Contracts\AcademicGateway;
+use App\Exceptions\AcademicGatewayException;
+use Illuminate\Http\RedirectResponse;
 use Illuminate\Http\Request;
+use Illuminate\Support\Arr;
+use Illuminate\Support\Facades\Log;
+use Illuminate\View\View;
 
 class AcademicInterfaceController extends Controller
 {
-    //
+    public function __construct(private readonly AcademicGateway $gateway) {}
+
+    public function show(Request $request): View
+    {
+        $module = $this->module();
+        $context = $this->context($request, $module);
+        $actions = [];
+
+        foreach ($module['actions'] as $key => $action) {
+            $action['payload'] = $this->resolvePayload($action['payload'] ?? [], $context);
+            $action['completed_at'] = $request->session()->get("academic.interface.completed.{$key}");
+            $actions[$key] = $action;
+        }
+
+        return view('academic-interface::interface', [
+            'module' => $module,
+            'actions' => $actions,
+            'context' => $context,
+            'identity' => $this->identity($request),
+            'lastResult' => $request->session()->get('academic.interface.last_result'),
+        ]);
+    }
+
+    public function execute(Request $request, string $action): RedirectResponse
+    {
+        $module = $this->module();
+        abort_unless(isset($module['actions'][$action]) && is_array($module['actions'][$action]), 404);
+
+        $step = $module['actions'][$action];
+        $context = $this->context($request, $module);
+        $expected = $this->resolvePayload($step['payload'] ?? [], $context);
+        $types = is_array($step['types'] ?? null) ? $step['types'] : [];
+        $optional = is_array($step['optional'] ?? null) ? $step['optional'] : [];
+        $rules = [];
+
+        foreach (array_keys($expected) as $field) {
+            $type = $types[$field] ?? 'string';
+            $presence = in_array($field, $optional, true) ? 'nullable' : 'required';
+            $rules["payload.{$field}"] = match ($type) {
+                'boolean' => [$presence, 'boolean'],
+                'integer' => [$presence, 'integer'],
+                'number' => [$presence, 'numeric'],
+                'email' => [$presence, 'email:rfc', 'max:255'],
+                'url' => [$presence, 'url:http,https', 'max:2048'],
+                'date' => [$presence, 'date_format:Y-m-d'],
+                default => [$presence, 'string', 'max:5000'],
+            };
+        }
+
+        /** @var array{payload?: array<string, mixed>} $validated */
+        $validated = $request->validate($rules);
+        $submitted = $validated['payload'] ?? [];
+        $payload = [];
+
+        foreach ($expected as $field => $default) {
+            $value = $submitted[$field] ?? $default;
+
+            if (in_array($field, $optional, true) && ($value === null || trim((string) $value) === '')) {
+                continue;
+            }
+
+            $payload[$field] = match ($types[$field] ?? 'string') {
+                'boolean' => filter_var($value, FILTER_VALIDATE_BOOL),
+                'integer' => (int) $value,
+                'number' => (float) $value,
+                default => trim((string) $value),
+            };
+        }
+
+        if (! $this->roleAllowed($request, $step)) {
+            return back()->withInput()->with('academic_error', [
+                'status' => 7,
+                'rpc' => (string) $step['rpc'],
+                'message' => 'El rol de la sesión no puede ejecutar esta acción.',
+            ]);
+        }
+
+        $authenticated = (bool) ($step['authenticated'] ?? true);
+        $accessToken = $authenticated
+            ? (string) $request->session()->get((string) config('academic-interface.session.access_token'), '')
+            : '';
+
+        try {
+            $result = $this->gateway->invoke((string) $step['rpc'], $payload, $accessToken);
+        } catch (AcademicGatewayException $exception) {
+            Log::warning('Installed academic interface action failed.', [
+                'module' => $module['key'],
+                'action' => $action,
+                'rpc' => $exception->rpc,
+                'status_code' => $exception->statusCode,
+            ]);
+
+            return back()->withInput()->with('academic_error', [
+                'status' => $exception->statusCode,
+                'rpc' => $exception->rpc,
+                'message' => $this->friendlyStatus($exception),
+            ]);
+        }
+
+        foreach (($step['payload'] ?? []) as $field => $template) {
+            if (is_string($template) && preg_match('/^\{([a-z0-9_]+)\}$/', $template, $matches) === 1) {
+                $context[$matches[1]] = $payload[$field] ?? '';
+            }
+        }
+
+        foreach (($step['capture'] ?? []) as $contextKey => $path) {
+            $captured = data_get($result, $path);
+
+            if (is_scalar($captured) && (string) $captured !== '') {
+                $context[$contextKey] = $captured;
+            }
+        }
+
+        $request->session()->put([
+            'academic.interface.context' => $context,
+            "academic.interface.completed.{$action}" => now()->toIso8601String(),
+            'academic.interface.last_result' => [
+                'action' => $action,
+                'title' => (string) $step['title'],
+                'rpc' => (string) $step['rpc'],
+                'payload' => $this->redact($payload),
+                'response' => $this->redact($result),
+            ],
+        ]);
+
+        return back()->with('academic_success', "Acción {$step['title']} ejecutada correctamente.");
+    }
+
+    public function reset(Request $request): RedirectResponse
+    {
+        $request->session()->forget([
+            'academic.interface.context',
+            'academic.interface.completed',
+            'academic.interface.last_result',
+        ]);
+
+        return redirect()->route('academic.interface')->with('academic_success', 'Contexto reiniciado.');
+    }
+
+    /** @return array<string, mixed> */
+    private function module(): array
+    {
+        $module = config('academic-module');
+
+        if (! is_array($module) || ! isset($module['key'], $module['actions'])) {
+            abort(500, 'The academic interface module is not installed.');
+        }
+
+        return $module;
+    }
+
+    /**
+     * @param  array<string, mixed>  $module
+     * @return array<string, bool|float|int|string>
+     */
+    private function context(Request $request, array $module): array
+    {
+        $defaults = is_array($module['context_defaults'] ?? null) ? $module['context_defaults'] : [];
+        $identity = $this->identity($request);
+        $sessionContext = [
+            'session_user_id' => $identity['user_id'],
+            'session_identifier' => $identity['identifier'],
+            'session_email' => $identity['email'],
+            'session_role' => $identity['role'],
+        ];
+        $stored = $request->session()->get('academic.interface.context', []);
+        $stored = is_array($stored) ? $stored : [];
+
+        /** @var array<string, bool|float|int|string> $context */
+        $context = array_merge($sessionContext, $defaults, $stored);
+
+        if (($context['flow_id'] ?? '') === '') {
+            $context['flow_id'] = now('UTC')->format('YmdHis');
+            $request->session()->put('academic.interface.context', $context);
+        }
+
+        return $context;
+    }
+
+    /**
+     * @param  array<string, mixed>  $payload
+     * @param  array<string, bool|float|int|string>  $context
+     * @return array<string, mixed>
+     */
+    private function resolvePayload(array $payload, array $context): array
+    {
+        $replace = [];
+
+        foreach ($context as $key => $value) {
+            $replace['{'.$key.'}'] = (string) $value;
+        }
+
+        return Arr::map($payload, static fn (mixed $value): mixed => is_string($value)
+            ? strtr($value, $replace)
+            : $value);
+    }
+
+    /** @return array{user_id: string, identifier: string, email: string, role: string} */
+    private function identity(Request $request): array
+    {
+        $session = config('academic-interface.session');
+        $session = is_array($session) ? $session : [];
+
+        return [
+            'user_id' => (string) $request->session()->get((string) ($session['user_id'] ?? ''), ''),
+            'identifier' => (string) $request->session()->get((string) ($session['identifier'] ?? ''), ''),
+            'email' => (string) $request->session()->get((string) ($session['email'] ?? ''), ''),
+            'role' => (string) $request->session()->get((string) ($session['role'] ?? ''), ''),
+        ];
+    }
+
+    /** @param  array<string, mixed>  $step */
+    private function roleAllowed(Request $request, array $step): bool
+    {
+        $roles = $step['roles'] ?? [];
+
+        if (! is_array($roles) || $roles === []) {
+            return true;
+        }
+
+        $current = strtolower((string) $request->session()->get(
+            (string) config('academic-interface.session.role'),
+            '',
+        ));
+
+        return in_array($current, array_map(static fn (mixed $role): string => strtolower((string) $role), $roles), true);
+    }
+
+    /**
+     * @param  array<string, mixed>  $value
+     * @return array<string, mixed>
+     */
+    private function redact(array $value): array
+    {
+        $sensitive = ['password', 'temporary_password', 'newPassword', 'token', 'accessToken', 'refreshToken'];
+
+        foreach ($value as $key => $item) {
+            if (in_array((string) $key, $sensitive, true)) {
+                $value[$key] = '[redacted]';
+            } elseif (is_array($item)) {
+                $value[$key] = $this->redact($item);
+            }
+        }
+
+        return $value;
+    }
+
+    private function friendlyStatus(AcademicGatewayException $exception): string
+    {
+        $label = match ($exception->statusCode) {
+            3 => 'Argumento inválido',
+            5 => 'Registro no encontrado',
+            6 => 'El registro ya existe',
+            7 => 'Permiso denegado',
+            12 => 'RPC no publicado o no instalado',
+            14 => 'Servicio temporalmente no disponible',
+            16 => 'Sesión no autenticada o expirada',
+            default => 'El gateway rechazó la operación',
+        };
+
+        return "{$label}. Código gRPC {$exception->statusCode}.";
+    }
 }
