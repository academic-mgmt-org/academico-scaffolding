 namespace App\Http\Middleware;
 
+use App\Contracts\GatewayClient;
+use App\Exceptions\GatewayRpcException;
 use Closure;
 use Illuminate\Http\Request;
+use Illuminate\Support\Facades\Log;
 use Symfony\Component\HttpFoundation\Response;
 
 class RevokeGatewaySessionOnLogout
 {
+    public function __construct(private readonly GatewayClient $gateway) {}
+
     /**
      * Handle an incoming request.
      *
@@ -15,6 +20,28 @@ class RevokeGatewaySessionOnLogout
      */
     public function handle(Request $request, Closure $next): Response
     {
+        if (! $request->isMethod('POST') || ! $request->routeIs('logout')) {
+            return $next($request);
+        }
+
+        $accessTokenKey = (string) config('gateway.session.access_token');
+        $refreshTokenKey = (string) config('gateway.session.refresh_token');
+        $accessToken = (string) $request->session()->get($accessTokenKey, '');
+        $refreshToken = (string) $request->session()->get($refreshTokenKey, '');
+
+        try {
+            if ($accessToken !== '' && $refreshToken !== '') {
+                $this->gateway->logout($accessToken, $refreshToken);
+            }
+        } catch (GatewayRpcException $exception) {
+            Log::warning('Remote gateway logout failed; continuing with local logout.', [
+                'rpc' => $exception->rpc,
+                'status_code' => $exception->statusCode,
+            ]);
+        } finally {
+            $request->session()->forget(array_values((array) config('gateway.session')));
+        }
+
         return $next($request);
     }
 }
