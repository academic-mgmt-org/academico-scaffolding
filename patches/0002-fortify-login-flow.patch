+    /**
+     * Authenticate the generated login form against the remote gateway.
+     */
+    private function configureAuthentication(): void
+    {
+        Fortify::authenticateUsing(function (Request $request): ?User {
+            $gateway = app(GatewayClient::class);
+
+            try {
+                $gatewaySession = $gateway->login(
+                    $request->string(Fortify::username())->toString(),
+                    $request->string('password')->toString(),
+                );
+            } catch (GatewayRpcException $exception) {
+                if ($exception->isAuthenticationFailure()) {
+                    return null;
+                }
+
+                throw ValidationException::withMessages([
+                    Fortify::username() => [__('The authentication service is temporarily unavailable.')],
+                ]);
+            }
+
+            $submittedUsername = $request->string(Fortify::username())->toString();
+            $email = filter_var($gatewaySession['email'], FILTER_VALIDATE_EMAIL)
+                ? $gatewaySession['email']
+                : $submittedUsername;
+
+            try {
+                $user = User::query()->firstOrNew(['email' => $email]);
+                $user->name = $user->exists ? $user->name : Str::before($email, '@');
+
+                if (! $user->exists) {
+                    $user->password = Str::random(64);
+                    $user->email_verified_at = Carbon::now();
+                }
+
+                $user->save();
+
+                $request->session()->put([
+                    (string) config('gateway.session.access_token') => $gatewaySession['access_token'],
+                    (string) config('gateway.session.refresh_token') => $gatewaySession['refresh_token'],
+                    (string) config('gateway.session.session_id') => $gatewaySession['session_id'],
+                    (string) config('gateway.session.user_id') => $gatewaySession['user_id'],
+                    (string) config('gateway.session.identifier') => $gatewaySession['identifier'],
+                    (string) config('gateway.session.email') => $gatewaySession['email'],
+                    (string) config('gateway.session.role') => $gatewaySession['role'],
+                ]);
+
+                return $user;
+            } catch (Throwable $exception) {
+                try {
+                    $gateway->logout($gatewaySession['access_token'], $gatewaySession['refresh_token']);
+                } catch (Throwable) {
+                    // The original persistence error is more actionable.
+                }
+
+                throw $exception;
+            }
+        });
+    }
+
