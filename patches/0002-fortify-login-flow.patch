 namespace App\Http\Controllers;
 
+use App\Contracts\GatewayClient;
+use App\Exceptions\GatewayRpcException;
+use Illuminate\Http\RedirectResponse;
 use Illuminate\Http\Request;
+use Illuminate\Support\Facades\Auth;
+use Illuminate\Support\Facades\Log;
+use Illuminate\View\View;
 
 class NotificationController extends Controller
 {
+    public function __construct(private readonly GatewayClient $gateway) {}
+
     /**
      * Handle the incoming request.
      */
-    public function __invoke(Request $request)
+    public function __invoke(Request $request): View|RedirectResponse
+    {
+        $accessToken = (string) $request->session()->get(
+            (string) config('gateway.session.access_token'),
+            '',
+        );
+        $userId = (string) $request->session()->get(
+            (string) config('gateway.session.user_id'),
+            '',
+        );
+
+        if ($accessToken === '' || $userId === '') {
+            return $this->logoutAndRedirect($request);
+        }
+
+        try {
+            $unreadCount = $this->gateway->countUnread($accessToken, $userId);
+            $unread = $this->gateway->unreadNotifications(
+                $accessToken,
+                $userId,
+                max(1, $unreadCount),
+            );
+            $recent = $this->gateway->recentNotifications($accessToken, $userId, 5);
+
+            return view('notifications.index', [
+                'gatewayError' => null,
+                'unreadCount' => $unreadCount,
+                'unreadNotifications' => $unread,
+                'recentNotifications' => $recent,
+            ]);
+        } catch (GatewayRpcException $exception) {
+            if ($exception->isAuthenticationFailure()) {
+                return $this->logoutAndRedirect($request);
+            }
+
+            Log::warning('Unable to load gateway notifications.', [
+                'rpc' => $exception->rpc,
+                'status_code' => $exception->statusCode,
+            ]);
+
+            return view('notifications.index', [
+                'gatewayError' => __('Notifications are temporarily unavailable.'),
+                'unreadCount' => 0,
+                'unreadNotifications' => [],
+                'recentNotifications' => [],
+            ]);
+        }
+    }
+
+    private function logoutAndRedirect(Request $request): RedirectResponse
     {
-        //
+        Auth::guard('web')->logout();
+        $request->session()->invalidate();
+        $request->session()->regenerateToken();
+
+        return redirect()->route('login')->withErrors([
+            'email' => __('Your gateway session has expired. Please sign in again.'),
+        ]);
     }
 }
