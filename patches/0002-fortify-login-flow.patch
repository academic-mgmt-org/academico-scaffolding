 namespace App\Console\Commands;
 
+use App\Contracts\GatewayClient;
+use App\Exceptions\GatewayRpcException;
+use Closure;
 use Illuminate\Console\Attributes\Description;
 use Illuminate\Console\Attributes\Signature;
 use Illuminate\Console\Command;
+use RuntimeException;
+use Throwable;
 
-#[Signature('app:gateway-smoke-command')]
-#[Description('Command description')]
+#[Signature('gateway:smoke {--username= : Gateway username} {--no-prompt : Read credentials only from the environment}')]
+#[Description('Verify login, protected notifications, logout, and token revocation against the gateway')]
 class GatewaySmokeCommand extends Command
 {
     /**
      * Execute the console command.
      */
-    public function handle()
+    public function handle(GatewayClient $gateway): int
     {
-        //
+        $username = (string) ($this->option('username') ?: config('gateway.smoke.username'));
+        $password = (string) config('gateway.smoke.password');
+
+        if (! $this->option('no-prompt')) {
+            $username = $username !== '' ? $username : (string) $this->ask('Gateway username');
+            $password = $password !== '' ? $password : (string) $this->secret('Gateway password');
+        }
+
+        if ($username === '' || $password === '') {
+            $this->error('Gateway credentials are required. Set GATEWAY_SMOKE_USERNAME and GATEWAY_SMOKE_PASSWORD.');
+
+            return self::FAILURE;
+        }
+
+        $activeSession = null;
+
+        try {
+            $this->assertUnauthenticated(
+                fn () => $gateway->countUnread('', ''),
+                'notifications without authorization',
+            );
+
+            $activeSession = $gateway->login($username, $password);
+            $accessToken = $activeSession['access_token'];
+            $refreshToken = $activeSession['refresh_token'];
+            $userId = $activeSession['user_id'];
+
+            if ($accessToken === '' || $refreshToken === '' || $activeSession['session_id'] === '') {
+                throw new RuntimeException('Login did not return all required session values.');
+            }
+
+            $unreadCount = $gateway->countUnread($accessToken, $userId);
+            $unread = $gateway->unreadNotifications($accessToken, $userId, max(1, $unreadCount));
+            $recent = $gateway->recentNotifications($accessToken, $userId, 5);
+
+            $gateway->logout($accessToken, $refreshToken);
+            $activeSession = null;
+
+            $validation = $gateway->validateToken($accessToken);
+
+            if ($validation['is_valid']) {
+                throw new RuntimeException('ValidateToken accepted an access token after logout.');
+            }
+
+            $this->assertUnauthenticated(
+                fn () => $gateway->countUnread($accessToken, $userId),
+                'notifications with the revoked token',
+            );
+
+            $this->info(sprintf(
+                'Gateway smoke test passed: unread=%d, unread_list=%d, recent=%d.',
+                $unreadCount,
+                count($unread),
+                count($recent),
+            ));
+
+            return self::SUCCESS;
+        } catch (Throwable $exception) {
+            if ($exception instanceof GatewayRpcException) {
+                $this->error(sprintf(
+                    'Gateway smoke test failed at %s with status %d.',
+                    $exception->rpc,
+                    $exception->statusCode,
+                ));
+            } else {
+                $this->error('Gateway smoke test failed: '.$exception->getMessage());
+            }
+
+            return self::FAILURE;
+        } finally {
+            if (is_array($activeSession)) {
+                try {
+                    $gateway->logout($activeSession['access_token'], $activeSession['refresh_token']);
+                } catch (Throwable) {
+                    // Best-effort cleanup for a partially completed smoke test.
+                }
+            }
+        }
+    }
+
+    private function assertUnauthenticated(Closure $operation, string $scenario): void
+    {
+        try {
+            $operation();
+        } catch (GatewayRpcException $exception) {
+            if ($exception->isAuthenticationFailure()) {
+                return;
+            }
+
+            throw $exception;
+        }
+
+        throw new RuntimeException('The gateway accepted '.$scenario.'.');
     }
 }
